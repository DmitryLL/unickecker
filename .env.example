ADMIN_USER=admin
# Generate: python3 -c "import hashlib,os,base64; s=os.urandom(16); d=hashlib.scrypt(b'YOUR_PASSWORD',salt=s,n=16384,r=8,p=1,dklen=32); print('scrypt$'+base64.b64encode(s).decode()+'$'+base64.b64encode(d).decode())"
# IMPORTANT: in this file every "$" must be doubled to "$$" (docker compose interpolation).
ADMIN_PASSWORD_HASH=
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# ==== MSSQL подключения ====
# Любое из подключений можно настроить через env (для авто-деплоя без UI)
# ИЛИ через вкладку «Подключение к БД» в UI (значения попадают в
# /data/db_settings.json, пароль шифруется). Файл всегда перекрывает env.

# CPL — основная БД (Unistream.ControlPanel), используется в «Статусы операций»
MSSQL_CPL_HOST=
MSSQL_CPL_PORT=
MSSQL_CPL_DATABASE=
MSSQL_CPL_USER=
MSSQL_CPL_PASSWORD=

# USDB — главная база, проверка статуса по Alter_Control
MSSQL_USDB_HOST=
MSSQL_USDB_PORT=
MSSQL_USDB_DATABASE=
MSSQL_USDB_USER=
MSSQL_USDB_PASSWORD=

# Legacy (без префикса) — продолжают работать только для CPL, deprecated.
# Новые установки используйте MSSQL_CPL_* / MSSQL_USDB_*.
# MSSQL_HOST=
# MSSQL_PORT=
# MSSQL_DATABASE=
# MSSQL_USER=
# MSSQL_PASSWORD=

# Ключ для шифрования паролей в /data/db_settings.json (Fernet, base64 32 байта).
# Сгенерировать: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Если оставить пустым, ключ автогенерируется при первом старте и сохранится в
# /data/.settings_key (chmod 600). Для prod — задайте через env / Docker secret
# и удалите файл /data/.settings_key, чтобы ключ и шифротекст лежали врозь.
SETTINGS_ENCRYPTION_KEY=
